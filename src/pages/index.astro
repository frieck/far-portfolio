---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

const profileEntry = await getEntry("profile", "home");
const competenciesEntry = await getEntry("competencies", "core");
const experience = (await getCollection("experience")).sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime(),
);
const education = (await getCollection("education")).sort(
  (a, b) => a.data.order - b.data.order,
);

if (!profileEntry || !competenciesEntry) {
  throw new Error(
    "Missing content in src/content/profile/home.md or src/content/competencies/core.md",
  );
}

const profile = profileEntry.data;
const competencies = competenciesEntry.data;
const { Content: ProfileContent } = await render(profileEntry);
const BOOT_DURATION_MS = 3600;
const emailCodes = profile.email
  .split("")
  .map((char) => char.charCodeAt(0) + 11)
  .join(",");
---

<BaseLayout
  title="Felipe Augusto Rieck | FAR"
  description="Felipe Augusto Rieck portfolio — Staff/Principal Full-Stack Engineer."
>
  <div
    class="boot-terminal"
    data-boot-terminal
    data-boot-text={profile.bootMessage}
    data-boot-duration={BOOT_DURATION_MS}
    aria-hidden="true"
  >
    <div class="boot-window">
      <span class="boot-prompt">&gt;</span>
      <span data-boot-output></span>
      <span class="boot-cursor"></span>
    </div>
  </div>

  <section class="hero card reveal">
    <h1 class="glitch" data-text={profile.name}>{profile.name}</h1>
    <h2>{profile.role}</h2>
    <p class="lead">{profile.lead}</p>

    <div class="hero-actions">
      <a class="btn primary" href="#" data-contact-codes={emailCodes}>Contact</a>
      <a class="btn" href={profile.linkedin} target="_blank" rel="noreferrer"
        >LinkedIn</a
      >
    </div>
  </section>

  <section class="reveal">
    <h3>Summary</h3>
    <article class="card prose-invert">
      <ProfileContent />
    </article>
  </section>

  <section class="reveal">
    <h3>{competencies.title}</h3>
    <article class="card chips tilt-card">
      {competencies.items.map((item) => <span>{item}</span>)}
    </article>
  </section>

  <section>
    <h3>Experience</h3>
    <div class="timeline">
      {
        experience.map((item) => (
          <article class="card timeline-item tilt-card reveal">
            <div class="timeline-dot" />
            <h4>{item.data.role}</h4>
            <p class="company">
              {item.data.company} · {item.data.period}
            </p>
            {item.data.location && <p class="location">{item.data.location}</p>}
            <ul>
              {item.data.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
            <p class="stack">{item.data.technologies.join(" • ")}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="reveal">
    <h3>Languages</h3>
    <article class="card chips tilt-card">
      <span>Portuguese (Native)</span>
      <span>English (Full Professional)</span>
      <span>German (Elementary)</span>
      <span>Spanish (Limited Working)</span>
    </article>
  </section>

  <section class="reveal">
    <h3>Education</h3>
    <div class="timeline">
      {
        education.map((item) => (
          <article class="card timeline-item tilt-card">
            <div class="timeline-dot" />
            <h4>{item.data.degree}</h4>
            <p class="company">
              {item.data.institution} · {item.data.period}
            </p>
            <p class="location">{item.data.location}</p>
          </article>
        ))
      }
    </div>
  </section>

  <script is:inline>
    // Boot terminal
    if ("scrollRestoration" in history) {
      history.scrollRestoration = "manual";
    }
    window.scrollTo({ top: 0, left: 0, behavior: "instant" });

    const boot = document.querySelector("[data-boot-terminal]");
    const bootOutput = document.querySelector("[data-boot-output]");
    const revealVisibleContent = () => {
      document.querySelectorAll(".reveal").forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add("is-visible");
        }
      });
    };

    if (boot && bootOutput) {
      const text = boot.dataset.bootText || "";
      const duration = Number(boot.dataset.bootDuration || 3600);
      const typeDuration = Math.max(900, Math.min(duration - 900, 1900));
      const startedAt = performance.now();

      const typeFrame = (now) => {
        const progress = Math.min((now - startedAt) / typeDuration, 1);
        const length = Math.floor(progress * text.length);
        bootOutput.textContent = text.slice(0, length);

        if (progress < 1) {
          requestAnimationFrame(typeFrame);
        }
      };

      requestAnimationFrame(typeFrame);

      window.setTimeout(() => {
        bootOutput.textContent = text;
        window.scrollTo({ top: 0, left: 0, behavior: "instant" });
        document.body.classList.remove("is-booting");
        document.body.classList.add("boot-complete");
        revealVisibleContent();
        window.setTimeout(() => {
          document.body.classList.remove("boot-complete");
        }, 1600);
      }, duration);
    } else {
      window.scrollTo({ top: 0, left: 0, behavior: "instant" });
      document.body.classList.remove("is-booting");
      document.body.classList.add("boot-complete");
      revealVisibleContent();
      window.setTimeout(() => {
        document.body.classList.remove("boot-complete");
      }, 1600);
    }

    // Reveal on scroll
    const reveals = document.querySelectorAll(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      },
      { threshold: 0.12 },
    );
    reveals.forEach((el) => io.observe(el));

    // Cursor glow
    const glow = document.getElementById("cursor-glow");
    window.addEventListener("mousemove", (e) => {
      if (glow) {
        glow.style.left = `${e.clientX}px`;
        glow.style.top = `${e.clientY}px`;
      }
    });

    // Contact link
    const contactLink = document.querySelector("[data-contact-codes]");
    contactLink?.addEventListener("click", (e) => {
      e.preventDefault();
      const encoded = contactLink.getAttribute("data-contact-codes") || "";
      const email = encoded
        .split(",")
        .map((code) => String.fromCharCode(Number(code) - 11))
        .join("");

      window.location.href = `mailto:${email}`;
    });

    // Tilt cards
    const cards = document.querySelectorAll(".tilt-card");
    cards.forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        const x = e.clientX - r.left;
        const y = e.clientY - r.top;
        const rx = (y / r.height - 0.5) * -8;
        const ry = (x / r.width - 0.5) * 10;
        card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;
      });
      card.addEventListener("mouseleave", () => {
        card.style.transform =
          "perspective(900px) rotateX(0deg) rotateY(0deg) translateY(0)";
      });
    });
  </script>
</BaseLayout>
